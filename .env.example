# Copy file này thành .env và điền thông tin Supabase của bạn
# Copy this file to .env and fill in your Supabase credentials

VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxx"
VITE_SUPABASE_ANON_KEY="your-anon-jwt-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# ⚠️ CẢNH BÁO: KHÔNG bao giờ commit file .env thật lên GitHub!
# VITE_SUPABASE_DB_PASSWORD và VITE_SUPABASE_DB_URL chứa mật khẩu database
# Chỉ dùng cho local dev hoặc server backend (không dùng trong frontend)
VITE_SUPABASE_DB_PASSWORD="your-database-password"
VITE_SUPABASE_DB_URL="postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres"

# Google Gemini API Key cho Chatbot AI
VITE_GEMINI_API_KEY="your-gemini-api-key"
